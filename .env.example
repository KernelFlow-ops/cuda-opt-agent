# ────────────────────────────────────────────────────────────
# LLM 配置
# ────────────────────────────────────────────────────────────

# LLM 提供商: anthropic | openai
LLM_PROVIDER=openai

# Anthropic 配置（LLM_PROVIDER=anthropic 时生效）
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI 配置（LLM_PROVIDER=openai 时生效）
OPENAI_BASE_URL=https://api.hustai.uk
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-5.5

# 是否开启 token 流式输出到终端
LLM_STREAM=true

# ────────────────────────────────────────────────────────────
# Web 搜索（外部知识注入）
# 优先级: Exa > Tavily > SerpAPI，留空则跳过该搜索源
# 注意: .env.example 只是模板，不会被自动加载；复制为 .env 后填写真实 key
# ────────────────────────────────────────────────────────────

# Exa 语义搜索（推荐，效果最好）https://exa.ai
# 需要安装可选依赖: pip install exa_py
EXA_API_KEY=

# Tavily 搜索（备选）https://tavily.com
TAVILY_API_KEY=

# SerpAPI Google 搜索（最后备选）https://serpapi.com
SERPAPI_API_KEY=

# bootstrap 阶段是否自动搜索参考实现（CUTLASS/FlashAttention 等）
ENABLE_WEB_SEARCH_BASELINE=true

# bootstrap 阶段最多发起多少次搜索调用（运行时硬上限 20）
BOOTSTRAP_WEB_SEARCH_MAX_CALLS=20

# bootstrap 阶段最多注入多少条去重搜索结果到 prompt
BOOTSTRAP_WEB_SEARCH_MAX_RESULTS=12

# bootstrap 阶段每个 query 请求多少条候选结果
BOOTSTRAP_WEB_SEARCH_PER_QUERY_RESULTS=3

# 连续失败几次后触发 web 搜索注入外部知识
WEB_SEARCH_ON_FAILURE_THRESHOLD=2

# 认为接近 kernel launch overhead 的延迟下界（ms），用于 tiny-kernel 判断
LAUNCH_FLOOR_MS=0.005

# trial 延迟 / 当前 best 延迟达到该倍数时记为 catastrophic regression
CATASTROPHIC_REGRESSION_THRESHOLD=3.0

# 连续 catastrophic regression 达到该次数后在 prompt/log 中提示降低风险
CATASTROPHIC_STREAK_LIMIT=2

# tiny kernel 下连续 reject 达到该次数后启用更保守的 HP 过滤提示
TINY_KERNEL_REJECT_LIMIT=3


# ────────────────────────────────────────────────────────────
# 优化流程控制
# ────────────────────────────────────────────────────────────

# 最大迭代轮数
MAX_ITERATIONS=5

# 连续拒绝多少次后自动停止
CONSECUTIVE_REJECT_LIMIT=5

# 接受 trial 所需的最低相对提升（0.005 = 0.5%）
ACCEPT_EPSILON=0.05

# 编译失败时最多修复尝试次数
COMPILE_REPAIR_MAX_RETRIES=3

# decide 选到黑名单方法时最多重选次数
DECIDE_RESELECT_MAX_RETRIES=3

# 默认数据类型: fp16 | bf16 | fp32 | fp64 | int8
DEFAULT_DTYPE=fp16


# ────────────────────────────────────────────────────────────
# 超参数搜索
# ────────────────────────────────────────────────────────────

# 每轮 HP 搜索生成的候选方案数
HP_CANDIDATE_COUNT=5

# 并行编译 worker 数（0=自动，1=串行）
HP_COMPILE_WORKERS=0

# HP 候选 LLM 调用最大并发数
HP_LLM_CONCURRENCY=3

# HP 候选正确性验证修复最大次数
HP_CORRECTNESS_REPAIR_MAX=2


# ────────────────────────────────────────────────────────────
# Benchmark 参数
# ────────────────────────────────────────────────────────────

# Warmup 轮数（排除 GPU 预热影响）
BENCHMARK_WARMUP_ROUNDS=5

# 正式测量轮数
BENCHMARK_MEASURE_ROUNDS=20

# 多 shape 延迟聚合方式: mean | worst | weighted
MULTI_SHAPE_AGGREGATOR=mean


# ────────────────────────────────────────────────────────────
# NCU (Nsight Compute) 剖析
# ────────────────────────────────────────────────────────────

# NCU 剖析时 kernel 执行总次数
NCU_LAUNCH_COUNT=3

# NCU Warmup 轮数
NCU_WARMUP_ROUNDS=2

# NCU 测量轮数
NCU_PROFILE_ROUNDS=5


# ────────────────────────────────────────────────────────────
# 编译与硬件
# ────────────────────────────────────────────────────────────

# 使用的 GPU 编号，多卡用逗号分隔（留空=使用全部）
# 示例: GPU_IDS=0 或 GPU_IDS=0,1,2,3
GPU_IDS=0

# nvcc 并行编译线程数（0=使用 nvcc 默认值）
NVCC_PARALLEL_THREADS=0

# 正确性验证最大并发数
CORRECTNESS_MAX_PARALLEL=2


# ────────────────────────────────────────────────────────────
# 功能开关
# ────────────────────────────────────────────────────────────

# bootstrap 后是否对比 cuBLAS/cuDNN 等库的性能基线
ENABLE_LIBRARY_COMPARISON=false

# 是否在 prompt 中使用代码 diff（减少 token 用量）
USE_CODE_DIFF=true

# 是否使用 tool use / function calling 模式获取结构化输出
USE_TOOL_USE=true


# ────────────────────────────────────────────────────────────
# 路径配置
# ────────────────────────────────────────────────────────────

# 运行记录保存目录（相对于工作目录）
RUNS_DIR=runs

# 本地知识库目录（存放自定义 CUDA 优化知识条目）
KNOWLEDGE_BASE_DIR=knowledge_base


# ────────────────────────────────────────────────────────────
# 终端编码（Windows 用户可能需要调整）
# auto | utf-8 | gbk | default
# ────────────────────────────────────────────────────────────
CONSOLE_ENCODING=auto
