# === LLM Provider ===
# Choose one: anthropic / openai
LLM_PROVIDER=openai

# Anthropic
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (alternative)
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# === Agent Settings ===
MAX_ITERATIONS=7
CONSECUTIVE_REJECT_LIMIT=5
ACCEPT_EPSILON=0.005
COMPILE_REPAIR_MAX_RETRIES=3
HP_CANDIDATE_COUNT=5
BENCHMARK_WARMUP_ROUNDS=5
BENCHMARK_MEASURE_ROUNDS=20
NCU_LAUNCH_COUNT=5
NCU_WARMUP_ROUNDS=2
NCU_PROFILE_ROUNDS=2

# === Paths ===
RUNS_DIR=runs
KNOWLEDGE_BASE_DIR=knowledge_base

# === Logging ===
LOG_LEVEL=INFO
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
